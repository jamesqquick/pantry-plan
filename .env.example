# Turso (libSQL) — required for app at runtime and for migrate deploy
TURSO_DATABASE_URL="libsql://your-db-xxx.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token"

# Creating migrations: use `npm run migrate:dev -- --name <migration_name>` (no extra env var needed).
# Then apply to Turso: turso db shell <dbname> < prisma/migrations/<timestamp>_<name>/migration.sql

AUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Recipe-from-image extraction and optional LLM-backed ingredient mapping when parsing recipes (optional)
OPENAI_API_KEY=""
